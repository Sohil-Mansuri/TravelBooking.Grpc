    {
      "name": "🏨 Hotels",
      "item": [
        {
          "name": "Search Hotels",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has hotels array', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.hotels).to.be.an('array');",
                  "    pm.expect(json.totalResults).to.be.above(0);",
                  "});",
                  "",
                  "// Auto-save first hotelId",
                  "const json = pm.response.json();",
                  "if (json.hotels && json.hotels.length > 0) {",
                  "    pm.collectionVariables.set('hotelId', json.hotels[0].hotelId);",
                  "    console.log('Saved hotelId:', json.hotels[0].hotelId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"city\": \"Delhi\",\n  \"checkIn\": \"2025-12-01\",\n  \"checkOut\": \"2025-12-05\",\n  \"guests\": 2,\n  \"rooms\": 1,\n  \"minStars\": 3,\n  \"maxPricePerNight\": 15000\n}",
              "options": {
