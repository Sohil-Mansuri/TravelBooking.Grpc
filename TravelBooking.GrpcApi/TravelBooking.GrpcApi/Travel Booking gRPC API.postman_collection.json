{
  "info": {
    "_postman_id": "88d9cab9-a760-46d9-9f9c-126e0dc2ac93",
    "name": "Travel Booking gRPC API",
    "description": "REST/JSON endpoints for Travel Booking gRPC API with JSON Transcoding.\n\nBase URL: https://localhost:5001\n\n**Setup:**\n1. Run the API: `dotnet run`\n2. If SSL error, disable SSL verification in Postman Settings → General → SSL certificate verification OFF\n3. All endpoints return JSON automatically via gRPC JSON Transcoding",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "28763933"
  },
  "item": [
    {
      "name": "🛫 Flights",
      "item": [
        {
          "name": "Search Flights",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has flights array', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.flights).to.be.an('array');",
                  "    pm.expect(json.totalResults).to.be.above(0);",
                  "});",
                  "pm.test('Response time < 2000ms', () => pm.expect(pm.response.responseTime).to.be.below(2000));",
                  "",
                  "// Auto-save first flightId for later requests",
                  "const json = pm.response.json();",
                  "if (json.flights && json.flights.length > 0) {",
                  "    pm.collectionVariables.set('flightId', json.flights[0].flightId);",
                  "    console.log('Saved flightId:', json.flights[0].flightId);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"origin\": \"BOM\",\n    \"destination\": \"DEL\",\n    \"departureDate\": \"2025-12-01\",\n    \"returnDate\": \"\",\n    \"passengers\": 2,\n    \"cabinClass\": \"ECONOMY\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/flights/search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "flights",
                "search"
              ]
            },
            "description": "Search available flights between two cities.\n\n**cabinClass options:** `ECONOMY`, `PREMIUM_ECONOMY`, `BUSINESS`, `FIRST`\n\n**origin/destination:** Use IATA airport codes e.g. BOM, DEL, BLR, HYD, MAA, CCU"
          },
          "response": []
        },
        {
          "name": "Search Flights - Business Class",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\": \"BOM\",\n  \"destination\": \"BLR\",\n  \"departureDate\": \"2025-12-10\",\n  \"returnDate\": \"2025-12-15\",\n  \"passengers\": 1,\n  \"cabinClass\": \"BUSINESS\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/flights/search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "flights",
                "search"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Flight Pricing",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has pricing fields', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.totalPrice).to.be.a('number');",
                  "    pm.expect(json.currency).to.eql('INR');",
                  "    pm.expect(json.breakdown).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/flights/{{flightId}}/pricing?passengers=2&cabinClass=ECONOMY",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "flights",
                "{{flightId}}",
                "pricing"
              ],
              "query": [
                {
                  "key": "passengers",
                  "value": "2"
                },
                {
                  "key": "cabinClass",
                  "value": "ECONOMY"
                }
              ]
            },
            "description": "Get full price breakdown for a specific flight including base fare, taxes, and fees.\n\nPrice is valid for 15 minutes (see `priceValidUntil` in response)."
          },
          "response": []
        },
        {
          "name": "Get Flight Pricing - Business",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
