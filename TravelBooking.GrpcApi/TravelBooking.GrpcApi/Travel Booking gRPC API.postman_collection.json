    {
      "name": "📋 Bookings",
      "item": [
        {
          "name": "Create Booking (Flight + Hotel)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Booking confirmed', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('CONFIRMED');",
                  "    pm.expect(json.bookingId).to.be.a('string');",
                  "    pm.expect(json.pnrCode).to.be.a('string');",
                  "});",
                  "",
                  "// Auto-save bookingId for Get/Cancel requests",
                  "const json = pm.response.json();",
                  "if (json.bookingId) {",
                  "    pm.collectionVariables.set('bookingId', json.bookingId);",
                  "    console.log('Saved bookingId:', json.bookingId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flightId\": \"{{flightId}}\",\n  \"hotelId\": \"{{hotelId}}\",\n  \"passengers\": 1,\n  \"cabinClass\": \"ECONOMY\",\n  \"passengerDetails\": [\n    {\n      \"firstName\": \"Rahul\",\n      \"lastName\": \"Sharma\",\n      \"dateOfBirth\": \"1990-05-15\",\n      \"passportNumber\": \"A1234567\",\n      \"nationality\": \"IN\"\n    }\n  ],\n  \"contact\": {\n    \"email\": \"rahul.sharma@example.com\",\n    \"phone\": \"+91-9999999999\"\n  },\n  \"paymentToken\": \"pay_test_token_xyz\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/bookings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "bookings"
              ]
            },
            "description": "Create a booking with flight + optional hotel.\n\nThe `bookingId` from the response is auto-saved to the `{{bookingId}}` collection variable for use in Get and Cancel requests."
          },
          "response": []
        },
        {
          "name": "Create Booking (Flight Only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flightId\": \"FL002\",\n  \"hotelId\": \"\",\n  \"passengers\": 2,\n  \"cabinClass\": \"ECONOMY\",\n  \"passengerDetails\": [\n    {\n      \"firstName\": \"Priya\",\n      \"lastName\": \"Patel\",\n      \"dateOfBirth\": \"1995-08-20\",\n      \"passportNumber\": \"B9876543\",\n      \"nationality\": \"IN\"\n    },\n    {\n      \"firstName\": \"Amit\",\n      \"lastName\": \"Patel\",\n      \"dateOfBirth\": \"1993-03-10\",\n      \"passportNumber\": \"B9876544\",\n      \"nationality\": \"IN\"\n    }\n  ],\n  \"contact\": {\n    \"email\": \"priya.patel@example.com\",\n    \"phone\": \"+91-8888888888\"\n  },\n  \"paymentToken\": \"pay_test_token_abc\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/bookings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "bookings"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has booking details', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.bookingId).to.be.a('string');",
                  "    pm.expect(json.status).to.be.oneOf(['CONFIRMED', 'PENDING', 'CANCELLED']);",
                  "    pm.expect(json.pnrCode).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/bookings/{{bookingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "bookings",
                "{{bookingId}}"
              ]
            },
            "description": "Fetch booking details by ID.\n\n`{{bookingId}}` is auto-populated after running **Create Booking**."
          },
          "response": []
        },
        {
          "name": "Cancel Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Cancellation successful', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.refundAmount).to.be.a('number');",
                  "    pm.expect(json.message).to.include('cancelled');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/bookings/{{bookingId}}?reason=Change of plans",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "bookings",
                "{{bookingId}}"
              ],
              "query": [
                {
                  "key": "reason",
                  "value": "Change of plans"
                }
              ]
            },
            "description": "Cancel a booking and get refund details.\n\n`{{bookingId}}` is auto-populated after running **Create Booking**."
          },
          "response": []
        }
      ]
    },
