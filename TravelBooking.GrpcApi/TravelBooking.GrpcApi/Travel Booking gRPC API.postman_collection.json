                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "hotels",
                "search"
              ]
            },
            "description": "Search available hotels in a city.\n\nFilter by `minStars` (1-5) and `maxPricePerNight` in INR."
          },
          "response": []
        },
