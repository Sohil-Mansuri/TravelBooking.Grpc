<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <Protobuf Include="Protos\travel.proto" GrpcServices="Server" />

    <!-- Google API protos required for HTTP/JSON transcoding annotations -->
    <Protobuf Include="google\api\annotations.proto" GrpcServices="None" />
    <Protobuf Include="google\api\http.proto"        GrpcServices="None" />
  </ItemGroup>

  <ItemGroup>
    <!-- gRPC core -->
    <PackageReference Include="Grpc.AspNetCore" Version="2.62.0" />

    <!-- REST/JSON transcoding — turns gRPC into HTTP/JSON automatically -->
    <PackageReference Include="Microsoft.AspNetCore.Grpc.JsonTranscoding" Version="8.0.0" />

    <!-- Swagger UI for the JSON endpoints -->
    <PackageReference Include="Microsoft.AspNetCore.Grpc.Swagger" Version="0.3.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.5.0" />
  </ItemGroup>

</Project>
